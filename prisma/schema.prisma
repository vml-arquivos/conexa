generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id        String    @id @default(uuid())
  name      String
  planType  String    @default("PRO") // BASIC, PRO, ENTERPRISE
  students  Student[]
  inventory InventoryItem[]
  createdAt DateTime  @default(now())
}

model Student {
  id          String   @id @default(uuid())
  name        String
  birthDate   DateTime?
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE, EVADED
  
  // DADOS FLEXÍVEIS (O SEGREDO DO SISTEMA)
  // healthData: { "alergias": [], "medicamentos": [], "tea": boolean }
  // academicData: { "notas": [], "historico": [] }
  healthData  Json?
  academicData Json?
  attendance   Json?   // { "faltasConsecutivas": 0, "total": 0 }

  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  classId     String?  // ID da turma (ex: "Berçário 1")
}

model InventoryItem {
  id           String   @id @default(uuid())
  name         String
  category     String   // HIGIENE, PEDAGOGICO, ALIMENTACAO
  quantity     Int
  minThreshold Int      @default(10)
  unit         String   @default("un")
  
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id])
}
